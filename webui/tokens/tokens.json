{
  "_meta": { "version": "1.0.0", "rule": "只改这个文件，不改组件代码" },

 "color": {
  "primary":          "#1A1A1A",
  "primary-hover":    "#333333",
  "primary-light":    "rgba(26,26,26,0.06)",

  "bg-base":          "#F5F0E8",
  "bg-raised":        "#FFFFFF",
  "bg-overlay":       "#EDECE8",
  "bg-input":         "#FFFFFF",
  "bg-card":          "#FFFFFF",

  "text-primary":     "#1A1A1A",
  "text-secondary":   "#6B6B6B",
  "text-muted":       "#ABABAB",
  "text-inverse":     "#FFFFFF",

  "separator":        "rgba(26,26,26,0.08)",
  "border":           "rgba(26,26,26,0.10)",

  "success":          "#2D6A4F",
  "danger":           "#C0392B",
  "warning":          "#E67E22",
  "accent":           "#1A1A1A",

  "radar-fill":       "rgba(26,26,26,0.15)",
  "radar-stroke":     "#1A1A1A",

  "light-mode":       true
},
  "typography": {
    "large-title": { "size": 48, "weight": 700, "lineHeight": 41 },
    "title-1":     { "size": 34, "weight": 700, "lineHeight": 34 },
    "title-2":     { "size": 22, "weight": 700, "lineHeight": 28 },
    "title-3":     { "size": 20, "weight": 600, "lineHeight": 25 },
    "headline":    { "size": 17, "weight": 600, "lineHeight": 22 },
    "body":        { "size": 17, "weight": 400, "lineHeight": 22 },
    "callout":     { "size": 16, "weight": 400, "lineHeight": 21 },
    "subheadline": { "size": 15, "weight": 400, "lineHeight": 20 },
    "footnote":    { "size": 13, "weight": 400, "lineHeight": 18 },
    "caption":     { "size": 12, "weight": 400, "lineHeight": 16 },
    "timer":       { "size": 96, "weight": 200, "lineHeight": 96, "tracking": -4 }
  },

  "spacing": {
    "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 40, "xxl": 64
  },

  "radius": {
    "sm": 8, "md": 12, "card": 16, "modal": 20, "pill": 999
  },

  "shadow": {
    "card":  "0 2px 16px rgba(0,0,0,0.4)",
    "modal": "0 8px 40px rgba(0,0,0,0.6)",
    "glow":  "0 0 24px rgba(245,158,11,0.4)"
  },

  "duration": {
    "fast": "150ms", "normal": "280ms", "slow": "450ms", "focus": "600ms"
  },

  "easing": {
    "default": "cubic-bezier(0.4,0,0.2,1)",
    "spring":  "cubic-bezier(0.34,1.56,0.64,1)",
    "ios":     "cubic-bezier(0.25,0.46,0.45,0.94)"
  }
}
